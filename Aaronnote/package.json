{
  "name": "aaronnote",
  "version": "0.3.1",
  "description": "AaronNote: a roam-centered Typora-style Markdown editor.",
  "license": "MIT",
  "author": "Yanzhen Yu",
  "homepage": "https://yuyz0112.github.io/typora-web/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yuyz0112/typora-web.git"
  },
  "type": "module",
  "main": "./desktop/main.mjs",
  "module": "./dist/lib/typora-web.js",
  "exports": {
    ".": {
      "import": "./dist/lib/typora-web.js"
    },
    "./widgets.css": "./src/styles/widgets.css",
    "./theme-typora.css": "./src/styles/theme-typora.css",
    "./theme-github.css": "./src/styles/theme-github.css"
  },
  "files": [
    "dist/lib",
    "src/styles",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vp dev",
    "start": "node server/aaronnote-server.mjs",
    "start:vite": "vp dev --config vite.aaronnote.config.ts --host 127.0.0.1",
    "build:aaronnote": "tsc && vp build --config vite.aaronnote.config.ts",
    "build:desktop": "node --check desktop/main.mjs && node --check server/aaronnote-server.mjs && npm run build:aaronnote && electron-builder --mac dir",
    "build": "tsc && vp build",
    "build:lib": "tsc && vp build --config vite.lib.config.ts",
    "preview": "vp preview",
    "test": "vp test --run",
    "prepublishOnly": "npm run build:lib"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/turndown": "^5.0.6",
    "electron": "^37.8.0",
    "electron-builder": "^26.0.12",
    "happy-dom": "^20.9.0",
    "typescript": "~6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "dependencies": {
    "@github/copilot-language-server": "^1.489.0",
    "dompurify": "^3.4.4",
    "katex": "^0.16.47",
    "markdown-it": "^14.1.1",
    "markdown-it-emoji": "^3.0.0",
    "mermaid": "^11.15.0",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-model": "^1.25.4",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-transform": "^1.12.0",
    "prosemirror-view": "^1.41.8",
    "temml": "^0.13.3",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "build": {
    "appId": "com.aaronnote.desktop",
    "productName": "AaronNote",
    "asarUnpack": [
      "node_modules/@github/copilot-language-server/**/*",
      "node_modules/@github/copilot-language-server-*/*"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "server/**/*",
      "dist/aaronnote/**/*",
      "snippets/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../js",
        "to": "js",
        "filter": [
          "**/*"
        ]
      }
    ],
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown"
        ],
        "name": "Markdown Document",
        "role": "Editor"
      }
    ],
    "mac": {
      "identity": null,
      "icon": "build/Aaronnote.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dir"
      ]
    }
  }
}
