#!/usr/bin/env python3
from __future__ import annotations

from dataclasses import dataclass, field
from pathlib import Path
import json
import os
import re
import shutil
import subprocess
import sys


ROOT = Path(__file__).resolve().parents[1]
PUBLIC = ROOT / "public"
PUBLISH_STYLE = ROOT / "_typst" / "publish.typ"
PRIVATE_STYLE = ROOT / "_typst" / "private.typ"
PUBLISH_STATE = PUBLIC / ".publish-state.json"
PUBLISH_BASE_URL = os.environ.get("PUBLISH_BASE_URL", "")
ASSET_VERSION = "20260511-typst"
IMAGE_EXTENSIONS = {".png", ".jpg", ".jpeg", ".gif", ".svg", ".webp", ".avif"}
STATIC_EXTENSIONS = IMAGE_EXTENSIONS | {".css", ".js", ".pdf"}
SKIP_DIRS = {".git", ".cache", ".direnv", ".venv", "node_modules", "public", "ltximg", "_typst", "__pycache__"}
NOTE_RE = re.compile(r"#note\(\s*\"([^\"]+)\"\s*\)\s*\[([^\]]+)\]")
IMAGE_RE = re.compile(r"#image\(\s*\"([^\"]+)\"")
METADATA_RE = re.compile(r"#metadata\s*\(\((.*?)\)\)\s*<note>", re.S)
FIELD_RE = re.compile(r"^\s*([a-zA-Z0-9_-]+)\s*:\s*(.+?)(?:,\s*)?$", re.M)
PUBLISH_INPUT_PATHS = (
    "roam",
    "_typst",
    "CV",
    "css",
    "js",
    "homepage.html",
    "notes.html",
    "bin/publish-site",
    "Makefile",
)
PRIVATE_PATH_PREFIXES = (
    Path("roam/daily"),
    Path("roam/project"),
)


@dataclass
class Note:
    path: Path
    rel_path: str
    id: str
    title: str
    date: str = "Undated"
    tags: list[str] = field(default_factory=list)
    aliases: list[str] = field(default_factory=list)
    summary: str = ""
    refs: list[str] = field(default_factory=list)
    backlinks: list[str] = field(default_factory=list)
    private: bool = False

    @property
    def link(self) -> str:
        return f"{Path(self.rel_path).with_suffix('').as_posix()}.pdf"

    @property
    def group_key(self) -> str:
        parent = Path(self.rel_path).parent.as_posix()
        return "Root" if parent == "." else parent

    @property
    def group_label(self) -> str:
        leaf = self.group_key.rsplit("/", 1)[-1]
        if leaf == "Root":
            return "Root"
        return leaf if leaf.isupper() else leaf.replace("-", " ").replace("_", " ").title()

    @property
    def section(self) -> str:
        return self.group_key.split("/", 1)[0]


def should_skip(path: Path) -> bool:
    return any(part in SKIP_DIRS for part in path.parts)


def parse_scalar(value: str) -> str:
    value = value.strip().rstrip(",").strip()
    if value.startswith('"') and value.endswith('"'):
        return value[1:-1].replace('\\"', '"')
    return value


def parse_value(value: str) -> object:
    stripped = value.strip().rstrip(",").strip()
    if stripped.startswith("("):
        return parse_tuple(stripped)
    if stripped in {"true", "false"}:
        return stripped == "true"
    return parse_scalar(stripped)


def parse_tuple(value: str) -> list[str]:
    return re.findall(r'"([^"]*)"', value)


def parse_metadata(text: str) -> dict[str, object] | None:
    match = METADATA_RE.search(text)
    if not match:
        return None
    data: dict[str, object] = {}
    for key, value in FIELD_RE.findall(match.group(1)):
        data[key] = parse_value(value)
    if data.get("kind") != "note" or not data.get("id"):
        return None
    return data


def truthy(value: object) -> bool:
    if isinstance(value, bool):
        return value
    return str(value or "").strip().lower() in {"true", "yes", "private", "hidden", "sealed", "no-export"}


def private_metadata_p(metadata: dict[str, object], tags: list[str]) -> bool:
    normalized_tags = {tag.lower() for tag in tags}
    visibility = str(metadata.get("visibility") or metadata.get("access") or "").strip().lower()
    return (
        truthy(metadata.get("private"))
        or truthy(metadata.get("hidden"))
        or truthy(metadata.get("sealed"))
        or metadata.get("publish") is False
        or visibility in {"private", "hidden", "sealed"}
        or bool(normalized_tags & {"private", "hidden", "sealed", "no-export", "noexport"})
    )


def private_path_p(rel_path: Path) -> bool:
    return any(rel_path == prefix or prefix in rel_path.parents for prefix in PRIVATE_PATH_PREFIXES)


def clean_typst_text(text: str) -> str:
    text = METADATA_RE.sub("", text)
    text = re.sub(r"#import[^\n]*|#show:[^\n]*|#set[^\n]*", "", text)
    text = NOTE_RE.sub(lambda m: m.group(2), text)
    text = re.sub(r"#\w+\s*\[|\]|\$|=+|//.*", " ", text)
    text = re.sub(r"[*_`#{}()]", " ", text)
    return " ".join(text.split())


def private_asset_paths(note: Note) -> set[Path]:
    if not note.private:
        return set()
    try:
        text = note.path.read_text(encoding="utf-8")
    except OSError:
        return set()
    paths: set[Path] = set()
    for raw_path in IMAGE_RE.findall(text):
        image_path = Path(raw_path)
        if image_path.is_absolute():
            paths.add(image_path.resolve())
        else:
            paths.add((note.path.parent / image_path).resolve())
    for rel_dir in (
        Path("img") / note.path.stem,
        Path("assets") / "img" / note.path.stem,
    ):
        directory = note.path.parent / rel_dir
        if directory.exists():
            paths.update(path.resolve() for path in directory.rglob("*") if path.is_file())
    return paths


def parse_note(path: Path) -> Note | None:
    text = path.read_text(encoding="utf-8")
    metadata = parse_metadata(text)
    if not metadata:
        return None
    rel = path.relative_to(ROOT)
    rel_path = rel.as_posix()
    tags = [str(tag) for tag in metadata.get("tags", [])]
    private = private_path_p(rel) or private_metadata_p(metadata, tags)
    refs = [target for target, _label in NOTE_RE.findall(text)]
    summary = "This note has been sealed by the administrator." if private else clean_typst_text(text)
    return Note(
        path=path,
        rel_path=rel_path,
        id=str(metadata["id"]),
        title=str(metadata.get("title") or path.stem),
        date=str(metadata.get("date") or "Undated"),
        tags=tags,
        aliases=[str(alias) for alias in metadata.get("aliases", [])],
        summary=summary[:180],
        refs=sorted(set(refs)),
        private=private,
    )


def find_notes() -> list[Note]:
    notes: list[Note] = []
    for path in ROOT.rglob("*.typ"):
        rel = path.relative_to(ROOT)
        if should_skip(rel) or path.name.endswith("~"):
            continue
        note = parse_note(path)
        if note:
            notes.append(note)
    return sorted(notes, key=lambda note: (note.date, note.title), reverse=True)


def deps_file_for(output_file: Path) -> Path:
    rel = output_file.relative_to(PUBLIC)
    return PUBLIC / ".deps" / rel.with_suffix(".json")


def publish_forced() -> bool:
    return os.environ.get("PUBLISH_FORCE") == "1"


def git_head() -> str | None:
    try:
        return subprocess.check_output(["git", "rev-parse", "HEAD"], cwd=ROOT, text=True).strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None


def git_inputs_dirty() -> bool:
    try:
        output = subprocess.check_output(
            ["git", "status", "--porcelain", "--", *PUBLISH_INPUT_PATHS],
            cwd=ROOT,
            text=True,
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        return True
    return bool(output.strip())


def publish_outputs_exist(notes: list[Note]) -> bool:
    required = [PUBLIC / "js" / "data.js", PUBLIC / "index.html", PUBLIC / "notes.html"]
    required.extend(PUBLIC / note.link for note in notes)
    cv_source = ROOT / "CV" / "main.typ"
    if cv_source.exists():
        required.append(ROOT / "CV" / "Aaron_He_CV.pdf")
    return all(path.exists() for path in required)


def publish_state_current(notes: list[Note], head: str | None) -> bool:
    if publish_forced() or not head or git_inputs_dirty() or not PUBLISH_STATE.exists():
        return False
    try:
        state = json.loads(PUBLISH_STATE.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return False
    return (
        state.get("gitHead") == head
        and state.get("dirty") is False
        and state.get("noteCount") == len(notes)
        and publish_outputs_exist(notes)
    )


def write_publish_state(notes: list[Note], compiled: int, skipped: int, cv_status: str, head: str | None) -> None:
    state = {
        "gitHead": head,
        "dirty": git_inputs_dirty(),
        "noteCount": len(notes),
        "compiled": compiled,
        "skipped": skipped,
        "cv": cv_status,
    }
    PUBLISH_STATE.write_text(json.dumps(state, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def path_from_dep(dep: str) -> Path:
    path = Path(dep)
    return path if path.is_absolute() else ROOT / path


def output_is_current(output_file: Path, deps_file: Path) -> bool:
    if publish_forced():
        return False
    if not output_file.exists() or not deps_file.exists():
        return False
    try:
        deps = json.loads(deps_file.read_text(encoding="utf-8")).get("inputs", [])
    except (OSError, json.JSONDecodeError):
        return False
    output_mtime = output_file.stat().st_mtime
    for dep in deps:
        dep_path = path_from_dep(str(dep))
        if not dep_path.exists() or dep_path.stat().st_mtime > output_mtime:
            return False
    return True


def deps_for_note(note: Note, notes_by_id: dict[str, Note]) -> set[str]:
    inputs = {note.path.relative_to(ROOT).as_posix(), "bin/publish-site"}
    inputs.add((PRIVATE_STYLE if note.private else PUBLISH_STYLE).relative_to(ROOT).as_posix())
    for ref in note.refs:
        target = notes_by_id.get(ref)
        if target:
            inputs.add(target.path.relative_to(ROOT).as_posix())
    return inputs


def publish_url_for(note: Note) -> str:
    prefix = PUBLISH_BASE_URL.rstrip("/")
    return f"{prefix}/{note.link}" if prefix else f"/{note.link}"


def typst_string(value: str) -> str:
    return json.dumps(value, ensure_ascii=False)


def publish_source_for(note: Note, temp_file: Path, notes_by_id: dict[str, Note]) -> None:
    source = note.path.read_text(encoding="utf-8")
    source = source.replace('"/_typst/note.typ"', '"/_typst/publish.typ"', 1)
    source = NOTE_RE.sub(
        lambda match: publish_note_link(match, notes_by_id),
        source,
    )
    temp_file.write_text(source, encoding="utf-8")


def private_source_for(note: Note, temp_file: Path) -> None:
    source = "\n".join(
        [
            '#import "/_typst/private.typ": *',
            "",
            "#private-note(",
            f"  id: {typst_string(note.id)},",
            f"  collection: {typst_string(note.group_label)},",
            f"  date: {typst_string(note.date)},",
            ")",
            "",
        ]
    )
    temp_file.write_text(source, encoding="utf-8")


def publish_note_link(match: re.Match[str], notes_by_id: dict[str, Note]) -> str:
    target = notes_by_id.get(match.group(1))
    if not target:
        return match.group(0)
    label = match.group(2)
    return f"#link({typst_string(publish_url_for(target))})[#text(fill: note-link-fill, underline([{label}]))]"


def normalize_deps(raw_deps_file: Path, temp_file: Path, note: Note, notes_by_id: dict[str, Note]) -> dict[str, list[str]]:
    try:
        raw_inputs = json.loads(raw_deps_file.read_text(encoding="utf-8")).get("inputs", [])
    except (OSError, json.JSONDecodeError):
        raw_inputs = []
    temp_real = temp_file.resolve()
    inputs = deps_for_note(note, notes_by_id)
    for dep in raw_inputs:
        dep_path = path_from_dep(str(dep)).resolve()
        if dep_path == temp_real:
            continue
        try:
            inputs.add(dep_path.relative_to(ROOT).as_posix())
        except ValueError:
            inputs.add(dep_path.as_posix())
    return {"inputs": sorted(inputs)}


def compile_note_pdf(note: Note, notes_by_id: dict[str, Note]) -> str:
    output_file = PUBLIC / note.link
    deps_file = deps_file_for(output_file)
    if output_is_current(output_file, deps_file):
        return "skipped"

    output_file.parent.mkdir(parents=True, exist_ok=True)
    deps_file.parent.mkdir(parents=True, exist_ok=True)
    temp_file = note.path.with_name(f".{note.path.stem}.publish.tmp.typ")
    raw_deps_file = deps_file.with_suffix(".raw.json")
    try:
        if note.private:
            private_source_for(note, temp_file)
        else:
            publish_source_for(note, temp_file, notes_by_id)
        subprocess.run(
            [
                "typst",
                "compile",
                "--root",
                str(ROOT),
                "--deps",
                str(raw_deps_file),
                str(temp_file),
                str(output_file),
            ],
            check=True,
            cwd=ROOT,
        )
        deps_file.write_text(
            json.dumps(normalize_deps(raw_deps_file, temp_file, note, notes_by_id), ensure_ascii=False, indent=2) + "\n",
            encoding="utf-8",
        )
    finally:
        temp_file.unlink(missing_ok=True)
        raw_deps_file.unlink(missing_ok=True)
    return "compiled"


def note_json(note: Note) -> dict[str, object]:
    private_summary = "This note has been sealed by the administrator."
    return {
        "key": note.id,
        "id": note.id,
        "title": note.title,
        "link": note.link,
        "date": note.date,
        "summary": private_summary if note.private else note.summary,
        "groupKey": note.group_key,
        "groupLabel": note.group_label,
        "section": note.section,
        "hidden": note.private,
        "private": note.private,
        "tags": [] if note.private else note.tags,
        "refs": note.refs,
        "backlinks": note.backlinks,
    }


def write_data(notes: list[Note]) -> None:
    js_dir = PUBLIC / "js"
    js_dir.mkdir(parents=True, exist_ok=True)
    tags = sorted({tag for note in notes for tag in note.tags})
    data = {
        "meta": {
            "generatedAt": subprocess.check_output(["date", "+%Y-%m-%d %H:%M:%S %z"], text=True).strip(),
            "noteCount": len(notes),
            "tagCount": len(tags),
        },
        "notes": [note_json(note) for note in notes],
    }
    (js_dir / "data.js").write_text(f"const SITE_DATA = {json.dumps(data, ensure_ascii=False, separators=(',', ':'))};\n", encoding="utf-8")


def _link_into_public(source: Path, target: Path) -> None:
    """Point TARGET at SOURCE via a relative symlink so dev edits stay live."""
    target.parent.mkdir(parents=True, exist_ok=True)
    rel = os.path.relpath(source, target.parent)
    if target.is_symlink() or target.exists():
        if target.is_symlink() and os.readlink(target) == rel:
            return
        target.unlink()
    target.symlink_to(rel)


def copy_static(notes: list[Note]) -> None:
    private_assets = set()
    for note in notes:
        private_assets.update(private_asset_paths(note))

    for path in ROOT.rglob("*"):
        if not path.is_file():
            continue
        if path.resolve() in private_assets:
            continue
        rel = path.relative_to(ROOT)
        if should_skip(rel) or path.name.startswith(".") or path.name.endswith("~"):
            continue
        if rel.parts and rel.parts[0] == "roam" and path.suffix.lower() not in IMAGE_EXTENSIONS:
            continue
        if path.suffix.lower() not in STATIC_EXTENSIONS:
            continue
        _link_into_public(path, PUBLIC / rel)

    for template, output in (("homepage.html", "index.html"), ("notes.html", "notes.html")):
        source = ROOT / template
        if source.exists():
            _link_into_public(source, PUBLIC / output)


def compile_cv() -> str:
    source = ROOT / "CV" / "main.typ"
    if not source.exists():
        return "missing"
    target = ROOT / "CV" / "Aaron_He_CV.pdf"
    if not publish_forced() and target.exists() and source.stat().st_mtime <= target.stat().st_mtime:
        return "skipped"
    subprocess.run(["typst", "compile", "--root", str(ROOT / "CV"), str(source), str(target)], check=True, cwd=ROOT)
    return "compiled"


def clean_stale_outputs(notes: list[Note]) -> None:
    expected_pdfs = {note.link for note in notes}
    private_assets = set()
    for note in notes:
        private_assets.update(private_asset_paths(note))
    roam_public = PUBLIC / "roam"
    if roam_public.exists():
        for html_file in roam_public.glob("**/*.html"):
            html_file.unlink()
        for source_asset in private_assets:
            try:
                rel = source_asset.relative_to(ROOT)
            except ValueError:
                continue
            public_asset = PUBLIC / rel
            if public_asset.exists() or public_asset.is_symlink():
                public_asset.unlink()
        for pdf_file in roam_public.glob("**/*.pdf"):
            rel = pdf_file.relative_to(PUBLIC).as_posix()
            if rel not in expected_pdfs:
                pdf_file.unlink()
                deps_file_for(pdf_file).unlink(missing_ok=True)
    for rel in ("diary.html", "sitemap-log.html", "CV/main.pdf"):
        (PUBLIC / rel).unlink(missing_ok=True)


def collect_notes() -> tuple[list[Note], dict[str, Note]]:
    PUBLIC.mkdir(exist_ok=True)
    notes = find_notes()
    notes_by_id = {note.id: note for note in notes}
    backlinks: dict[str, list[str]] = {note.id: [] for note in notes}
    for note in notes:
        note.refs = sorted(ref for ref in set(note.refs) if ref in notes_by_id and ref != note.id)
        for ref in note.refs:
            backlinks.setdefault(ref, []).append(note.id)
    for note in notes:
        note.backlinks = sorted(set(backlinks.get(note.id, [])))
    return notes, notes_by_id


def main() -> None:
    notes, notes_by_id = collect_notes()

    if "--record-state" in sys.argv[1:]:
        head = git_head()
        write_publish_state(notes, 0, len(notes), "recorded", head)
        print(f"Recorded publish state for git {head[:12] if head else 'unknown'}")
        return

    head = git_head()
    if publish_state_current(notes, head):
        print(f"Published {len(notes)} Typst notes to {PUBLIC} (git {head[:12]} unchanged, skipped)")
        return

    clean_stale_outputs(notes)
    cv_status = compile_cv()
    copy_static(notes)
    compiled = 0
    skipped = 0
    for note in notes:
        status = compile_note_pdf(note, notes_by_id)
        compiled += status == "compiled"
        skipped += status == "skipped"
    write_data(notes)
    write_publish_state(notes, compiled, skipped, cv_status, head)
    print(f"Published {len(notes)} Typst notes to {PUBLIC} ({compiled} compiled, {skipped} skipped, CV {cv_status})")


if __name__ == "__main__":
    main()
