#!/usr/bin/env python3
from __future__ import annotations

from collections.abc import Iterator
from dataclasses import dataclass, field
from pathlib import Path
import html
import json
import os
import re
import shutil
import subprocess
import sys
from urllib.parse import unquote


ROOT = Path(__file__).resolve().parents[1]
PUBLIC = ROOT / "public"
PUBLISH_STATE = PUBLIC / ".publish-state.json"
ASSET_VERSION = "20260517-md"
NOTE_THEME_VERSION = "20260518-aaronnote-toc"
IMAGE_EXTENSIONS = {".png", ".jpg", ".jpeg", ".gif", ".svg", ".webp", ".avif"}
STATIC_EXTENSIONS = IMAGE_EXTENSIONS | {".css", ".js", ".pdf"}
SKIP_DIRS = {".git", ".git-rewrite", ".cache", ".direnv", ".venv", "node_modules", "public", "release", "ltximg", "_typst", "__pycache__"}
PUBLISH_INPUT_PATHS = (
    "roam",
    "CV",
    "Aaronnote/aaronnote/style.css",
    "Aaronnote/aaronnote/published-toc.js",
    "Aaronnote/src",
    "Aaronnote/src/styles/theme-typora.css",
    "Aaronnote/src/styles/widgets.css",
    "css",
    "js",
    "kinds",
    "homepage.html",
    "notes.html",
    "bin/publish-site",
    "Makefile",
)
PRIVATE_PATH_PREFIXES = (
    Path("roam/daily"),
    Path("roam/project"),
)

FRONT_MATTER_RE = re.compile(r"\A---\s*\n(.*?)\n---\s*\n?", re.S)
ORG_META_RE = re.compile(r"\A#\+begin(?:_|\s+)meta\s*\n(.*?)^#\+end(?:_|\s+)meta\s*\n?", re.S | re.M)
ORG_ENV_RE = re.compile(r"(?ms)^#\+begin(?:_|\s+)([A-Za-z][\w-]*)(?:\s+([^\n]+?))?\s*\n(.*?)^\s*#\+end(?:_|\s+)\1\s*$")
MD_IMAGE_RE = re.compile(r"!\[[^\]]*\]\(([^)]+)\)")
MD_LINK_RE = re.compile(r"(?<!!)\[[^\]]+\]\(([^)]+)\)")
HTML_MD_LINK_RE = re.compile(r'href="([^"#?:]+)\.md((?:#[^"]*)?)"')
KIND_NAME_RE = re.compile(r"^[a-z0-9_-]+$")
DEFAULT_NOTE_KIND = "default"
DEFAULT_NOTE_KIND_ALIASES = {"", "default", "note"}


@dataclass
class Note:
    path: Path
    rel_path: str
    id: str
    title: str
    date: str = "Undated"
    tags: list[str] = field(default_factory=list)
    aliases: list[str] = field(default_factory=list)
    kind: str = DEFAULT_NOTE_KIND
    summary: str = ""
    search_text: str = ""
    refs: list[str] = field(default_factory=list)
    backlinks: list[str] = field(default_factory=list)
    private: bool = False

    @property
    def link(self) -> str:
        return f"{Path(self.rel_path).with_suffix('').as_posix()}.html"

    @property
    def group_key(self) -> str:
        parent = Path(self.rel_path).parent.as_posix()
        return "Root" if parent == "." else parent

    @property
    def group_label(self) -> str:
        leaf = self.group_key.rsplit("/", 1)[-1]
        if leaf == "Root":
            return "Root"
        return leaf if leaf.isupper() else leaf.replace("-", " ").replace("_", " ").title()

    @property
    def section(self) -> str:
        return self.group_key.split("/", 1)[0]


def should_skip(path: Path) -> bool:
    return any(part in SKIP_DIRS for part in path.parts)


def iter_project_files() -> Iterator[Path]:
    for dirpath, dirnames, filenames in os.walk(ROOT, onerror=lambda _err: None):
        rel_dir = Path(dirpath).relative_to(ROOT)
        dirnames[:] = [dirname for dirname in dirnames if not should_skip(rel_dir / dirname)]
        for filename in filenames:
            yield Path(dirpath) / filename


def parse_metadata_block(text: str) -> tuple[dict[str, object], str]:
    match = ORG_META_RE.match(text)
    if match:
        return parse_meta_lines(match.group(1), org_style=True), text[match.end():]
    match = FRONT_MATTER_RE.match(text)
    if not match:
        return {}, text
    return parse_meta_lines(match.group(1), org_style=False), text[match.end():]


def parse_meta_lines(raw: str, org_style: bool) -> dict[str, object]:
    metadata: dict[str, object] = {}
    current_list: str | None = None
    for raw_line in raw.splitlines():
        line = raw_line.rstrip()
        item = re.match(r"^\s*-\s*(.+?)\s*$", line)
        if item and current_list:
            metadata.setdefault(current_list, [])
            assert isinstance(metadata[current_list], list)
            metadata[current_list].append(parse_yaml_scalar(item.group(1)))
            continue
        pair = re.match(r"^([A-Za-z0-9_-]+):(?:\s*(.*))?$", line)
        if not pair:
            continue
        key, value = pair.group(1), (pair.group(2) or "").strip()
        if value == "":
            metadata[key] = []
            current_list = key
        else:
            if org_style and key in {"tags", "aliases", "refs"}:
                metadata[key] = [normalize_meta_string(part) for part in value.split(",") if part.strip()]
            else:
                metadata[key] = parse_yaml_scalar(value)
            current_list = None
    return metadata


def normalize_meta_string(value: object) -> str:
    return str(value).strip().strip('"').replace("\\_", "_")


def normalize_note_kind(value: object) -> str:
    if isinstance(value, list):
        value = value[0] if value else ""
    kind = normalize_meta_string(value).lower()
    if kind in DEFAULT_NOTE_KIND_ALIASES:
        return DEFAULT_NOTE_KIND
    if not KIND_NAME_RE.fullmatch(kind):
        return DEFAULT_NOTE_KIND
    return kind


def note_kind_from_metadata(metadata: dict[str, object]) -> str:
    return normalize_note_kind(metadata.get("kind") or metadata.get("kinds") or DEFAULT_NOTE_KIND)


def active_note_kind(note: Note) -> str:
    return "" if note.kind == DEFAULT_NOTE_KIND else note.kind


def script_json(value: object) -> str:
    return (
        json.dumps(value, ensure_ascii=False)
        .replace("<", "\\u003c")
        .replace(">", "\\u003e")
        .replace("&", "\\u0026")
    )


def parse_yaml_scalar(value: str) -> object:
    value = value.strip()
    if value in {"true", "false"}:
        return value == "true"
    if value.startswith('"') and value.endswith('"'):
        return value[1:-1].replace('\\"', '"').replace("\\\\", "\\").replace("\\_", "_")
    return value.replace("\\_", "_")


def truthy(value: object) -> bool:
    if isinstance(value, bool):
        return value
    return str(value or "").strip().lower() in {"true", "yes", "private", "hidden", "sealed", "no-export"}


def private_metadata_p(metadata: dict[str, object], tags: list[str]) -> bool:
    normalized_tags = {tag.lower() for tag in tags}
    visibility = str(metadata.get("visibility") or metadata.get("access") or "").strip().lower()
    return (
        truthy(metadata.get("private"))
        or truthy(metadata.get("hidden"))
        or truthy(metadata.get("sealed"))
        or metadata.get("publish") is False
        or visibility in {"private", "hidden", "sealed"}
        or bool(normalized_tags & {"private", "hidden", "sealed", "no-export", "noexport"})
    )


def private_path_p(rel_path: Path) -> bool:
    return any(rel_path == prefix or prefix in rel_path.parents for prefix in PRIVATE_PATH_PREFIXES)


def clean_markdown_text(text: str) -> str:
    _metadata, body = parse_metadata_block(text)
    body = re.sub(r"```.*?```", " ", body, flags=re.S)
    body = re.sub(r"<!--.*?-->", " ", body, flags=re.S)
    previous = None
    while previous != body:
        previous = body
        body = ORG_ENV_RE.sub(lambda match: match.group(3), body)
    body = re.sub(r"(?m)^#\+(?:begin|end)(?:_|\s+)[^\n]*", " ", body)
    body = re.sub(r"!\[[^\]]*\]\([^)]+\)", " ", body)
    body = re.sub(r"\[([^\]]+)\]\([^)]+\)", r"\1", body)
    body = re.sub(r"#+|[*_`$>|-]", " ", body)
    return " ".join(body.split())


def private_asset_paths(note: Note) -> set[Path]:
    if not note.private:
        return set()
    try:
        text = note.path.read_text(encoding="utf-8")
    except OSError:
        return set()
    paths: set[Path] = set()
    for raw_path in MD_IMAGE_RE.findall(text):
        asset_path = Path(raw_path.split("#", 1)[0])
        if asset_path.is_absolute():
            paths.add(asset_path.resolve())
        else:
            paths.add((note.path.parent / asset_path).resolve())
    for rel_dir in (
        Path("img") / note.path.stem,
        Path("assets") / "img" / note.path.stem,
    ):
        directory = note.path.parent / rel_dir
        if directory.exists():
            paths.update(path.resolve() for path in directory.rglob("*") if path.is_file())
    return paths


def parse_note(path: Path) -> Note | None:
    text = path.read_text(encoding="utf-8")
    metadata, _body = parse_metadata_block(text)
    note_id = metadata.get("id")
    if not note_id:
        return None
    rel = path.relative_to(ROOT)
    rel_path = rel.as_posix()
    tags = [str(tag) for tag in metadata.get("tags", [])] if isinstance(metadata.get("tags"), list) else []
    aliases = [str(alias) for alias in metadata.get("aliases", [])] if isinstance(metadata.get("aliases"), list) else []
    private = private_path_p(rel) or private_metadata_p(metadata, tags)
    refs = sorted(set(MD_LINK_RE.findall(text)))
    search_text = "This note has been sealed by the administrator." if private else clean_markdown_text(text)
    return Note(
        path=path,
        rel_path=rel_path,
        id=str(note_id),
        title=str(metadata.get("title") or path.stem),
        date=str(metadata.get("date") or "Undated"),
        tags=tags,
        aliases=aliases,
        kind=note_kind_from_metadata(metadata),
        summary=search_text[:180],
        search_text=search_text,
        refs=refs,
        private=private,
    )


def first_markdown_heading(text: str) -> str | None:
    for line in text.splitlines():
        match = re.match(r"^\s*#\s+(.+?)\s*$", line)
        if match:
            return match.group(1).strip()
    return None


def parse_note_for_export(path: Path) -> Note:
    note = parse_note(path)
    if note:
        return note

    text = path.read_text(encoding="utf-8")
    metadata, body = parse_metadata_block(text)
    rel = path.relative_to(ROOT)
    rel_path = rel.as_posix()
    tags = [str(tag) for tag in metadata.get("tags", [])] if isinstance(metadata.get("tags"), list) else []
    aliases = [str(alias) for alias in metadata.get("aliases", [])] if isinstance(metadata.get("aliases"), list) else []
    private = private_path_p(rel) or private_metadata_p(metadata, tags)
    return Note(
        path=path,
        rel_path=rel_path,
        id=str(metadata.get("id") or path.stem),
        title=str(metadata.get("title") or first_markdown_heading(body) or path.stem),
        date=str(metadata.get("date") or "Undated"),
        tags=tags,
        aliases=aliases,
        kind=note_kind_from_metadata(metadata),
        summary=clean_markdown_text(text)[:180],
        search_text=clean_markdown_text(text),
        refs=sorted(set(MD_LINK_RE.findall(text))),
        private=private,
    )


def find_notes() -> list[Note]:
    notes: list[Note] = []
    for path in iter_project_files():
        if path.suffix != ".md":
            continue
        rel = path.relative_to(ROOT)
        if should_skip(rel) or path.name.endswith("~"):
            continue
        if not rel.parts or rel.parts[0] != "roam":
            continue
        note = parse_note(path)
        if note:
            notes.append(note)
    return sorted(notes, key=lambda note: (note.date, note.title), reverse=True)


def deps_file_for(output_file: Path, output_root: Path = PUBLIC) -> Path:
    rel = output_file.relative_to(output_root)
    return output_root / ".deps" / rel.with_suffix(".json")


def publish_forced() -> bool:
    return os.environ.get("PUBLISH_FORCE") == "1"


def git_head() -> str | None:
    try:
        return subprocess.check_output(["git", "rev-parse", "HEAD"], cwd=ROOT, text=True).strip()
    except (subprocess.CalledProcessError, FileNotFoundError):
        return None


def git_inputs_dirty() -> bool:
    try:
        output = subprocess.check_output(["git", "status", "--porcelain", "--", *PUBLISH_INPUT_PATHS], cwd=ROOT, text=True)
    except (subprocess.CalledProcessError, FileNotFoundError):
        return True
    return bool(output.strip())


def publish_outputs_exist(notes: list[Note]) -> bool:
    required = [PUBLIC / "js" / "data.js", PUBLIC / "index.html", PUBLIC / "notes.html"]
    required.extend(PUBLIC / note.link for note in notes)
    return all(path.exists() for path in required)


def publish_state_current(notes: list[Note], head: str | None) -> bool:
    if publish_forced() or not head or git_inputs_dirty() or not PUBLISH_STATE.exists():
        return False
    try:
        state = json.loads(PUBLISH_STATE.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return False
    return (
        state.get("gitHead") == head
        and state.get("dirty") is False
        and state.get("noteCount") == len(notes)
        and publish_outputs_exist(notes)
    )


def write_publish_state(notes: list[Note], rendered: int, skipped: int, head: str | None) -> None:
    state = {
        "gitHead": head,
        "dirty": git_inputs_dirty(),
        "noteCount": len(notes),
        "rendered": rendered,
        "skipped": skipped,
    }
    PUBLISH_STATE.write_text(json.dumps(state, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")


def path_from_dep(dep: str) -> Path:
    path = Path(dep)
    return path if path.is_absolute() else ROOT / path


def output_is_current(output_file: Path, deps_file: Path) -> bool:
    if publish_forced():
        return False
    if not output_file.exists() or not deps_file.exists():
        return False
    try:
        deps = json.loads(deps_file.read_text(encoding="utf-8")).get("inputs", [])
    except (OSError, json.JSONDecodeError):
        return False
    output_mtime = output_file.stat().st_mtime
    for dep in deps:
        dep_path = path_from_dep(str(dep))
        if not dep_path.exists() or dep_path.stat().st_mtime > output_mtime:
            return False
    return True


def deps_for_note(note: Note) -> set[str]:
    deps = {
        note.path.relative_to(ROOT).as_posix(),
        "bin/publish-site",
        "Aaronnote/scripts/render-html.mjs",
        "Aaronnote/aaronnote/style.css",
        "Aaronnote/aaronnote/published-toc.js",
        "Aaronnote/src/styles/widgets.css",
        "Aaronnote/src/styles/theme-typora.css",
        "css/aaronnote-published.css",
    }
    src_dir = ROOT / "Aaronnote" / "src"
    if src_dir.exists():
        deps.update(path.relative_to(ROOT).as_posix() for path in src_dir.glob("**/*.ts"))
    deps.update(path.relative_to(ROOT).as_posix() for path in note_kind_asset_paths(note))
    return deps


def executable_from_path(value: str) -> str | None:
    value = value.strip()
    if not value:
        return None
    if os.sep in value:
        return value if Path(value).exists() else None
    return shutil.which(value)


def node_executable() -> str:
    for value in (
        os.environ.get("AARONNOTE_NODE", ""),
        os.environ.get("NODE_BINARY", ""),
        "node",
        "/opt/homebrew/bin/node",
        "/usr/local/bin/node",
        str(Path.home() / ".nix-profile" / "bin" / "node"),
        "/run/current-system/sw/bin/node",
    ):
        resolved = executable_from_path(value)
        if resolved:
            return resolved

    try:
        resolved = subprocess.check_output(
            ["/bin/zsh", "-lc", "command -v node"],
            text=True,
            stderr=subprocess.DEVNULL,
        ).strip()
    except (OSError, subprocess.CalledProcessError):
        resolved = ""
    if resolved:
        return resolved
    raise RuntimeError("Aaronnote renderer failed: node executable not found")


def render_aaronnote_markdown(text: str) -> str:
    try:
        result = subprocess.run(
            [node_executable(), "Aaronnote/scripts/render-html.mjs"],
            cwd=ROOT,
            input=json.dumps({"markdown": text}, ensure_ascii=False),
            text=True,
            check=True,
            capture_output=True,
        )
    except (OSError, subprocess.CalledProcessError) as err:
        stderr = err.stderr if isinstance(err, subprocess.CalledProcessError) else str(err)
        raise RuntimeError(f"Aaronnote renderer failed: {stderr}") from err
    try:
        return str(json.loads(result.stdout)["html"])
    except (json.JSONDecodeError, KeyError) as err:
        raise RuntimeError(f"Aaronnote renderer returned invalid JSON: {result.stdout[:500]}") from err


def render_markdown_body(note: Note, markdown_text: str) -> str:
    _metadata, body = parse_metadata_block(markdown_text)
    first_heading = re.compile(rf"\A\s*#\s+{re.escape(note.title)}\s*(?:\n+|\Z)")
    body = first_heading.sub("", body, count=1)
    rendered = render_aaronnote_markdown(body)
    rendered = HTML_MD_LINK_RE.sub(r'href="\1.html\2"', rendered)
    return rendered


def site_root_for(note_link: str) -> str:
    depth = len(Path(note_link).parent.parts)
    return "../" * depth or "./"


def note_page_html(note: Note, content_html: str, *, include_private_content: bool = False) -> str:
    root = site_root_for(note.link)
    body_class = "aaronnote-shell published-note-page"
    if note.private and not include_private_content:
        body_class += " hidden-note-page"
    kind = active_note_kind(note)
    if kind:
        body_class += f" note-kind-{kind}"
    if note.private and not include_private_content:
        content_html = (
            '<p class="sealed-note-message">This note has been sealed by the administrator.</p>'
        )
    note_title = html.escape(note.title)
    note_group = html.escape(note.group_label)
    note_date = html.escape(note.date)
    note_kind = html.escape(kind or DEFAULT_NOTE_KIND)
    note_kind_assets = note_kind_assets_html(note, root)
    return f"""<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{note_title} | Aaron He</title>
  <link rel="stylesheet" href="{root}Aaronnote/aaronnote/style.css?v={NOTE_THEME_VERSION}" />
  <link rel="stylesheet" href="{root}Aaronnote/src/styles/widgets.css?v={NOTE_THEME_VERSION}" />
  <link rel="stylesheet" href="{root}Aaronnote/src/styles/theme-typora.css?v={NOTE_THEME_VERSION}" />
  <link rel="stylesheet" href="{root}css/aaronnote-published.css?v={NOTE_THEME_VERSION}" />
{note_kind_assets}
</head>
<body class="{body_class}" data-note-kind="{note_kind}">
  <header class="aaronnote-toolbar">
    <div class="aaronnote-title">
      <strong>Aaronnote</strong>
      <span>{note_group} / {note_date}</span>
    </div>
    <nav class="aaronnote-actions" aria-label="Published note navigation">
      <a href="{root}index.html">Home</a>
      <a href="{root}notes.html">Archive</a>
    </nav>
    <span class="aaronnote-status">Published HTML</span>
  </header>
  <main class="aaronnote-body">
    <section class="aaronnote-editor">
      <div class="typora-web-wrap">
        <div class="typora-web-editor-host">
          <article id="content" class="ProseMirror" data-note-title="{note_title}" data-note-kind="{note_kind}">
            <h1 class="title">{note_title}</h1>
            {content_html}
          </article>
        </div>
      </div>
    </section>
    <aside class="aaronnote-floating-toc is-collapsed" data-floating-toc data-published-toc>
      <button type="button" data-toc-toggle aria-expanded="false">TOC</button>
      <nav data-toc-list aria-label="Table of contents"></nav>
    </aside>
  </main>
  <script type="module" src="{root}Aaronnote/aaronnote/published-toc.js?v={NOTE_THEME_VERSION}"></script>
</body>
</html>
"""


def render_note_html(
    note: Note,
    *,
    output_root: Path = PUBLIC,
    include_private_content: bool = False,
    force: bool = False,
) -> str:
    output_file = output_root / note.link
    deps_file = deps_file_for(output_file, output_root)
    if not force and not include_private_content and output_is_current(output_file, deps_file):
        return "skipped"
    output_file.parent.mkdir(parents=True, exist_ok=True)
    deps_file.parent.mkdir(parents=True, exist_ok=True)
    markdown_text = note.path.read_text(encoding="utf-8")
    output_file.write_text(
        note_page_html(
            note,
            render_markdown_body(note, markdown_text),
            include_private_content=include_private_content,
        ),
        encoding="utf-8",
    )
    deps_file.write_text(json.dumps({"inputs": sorted(deps_for_note(note))}, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
    return "rendered"


def note_json(note: Note) -> dict[str, object]:
    private_summary = "This note has been sealed by the administrator."
    return {
        "key": note.id,
        "id": note.id,
        "title": note.title,
        "link": note.link,
        "path": note.rel_path,
        "date": note.date,
        "summary": private_summary if note.private else note.summary,
        "searchText": private_summary if note.private else note.search_text,
        "groupKey": note.group_key,
        "groupLabel": note.group_label,
        "section": note.section,
        "hidden": note.private,
        "private": note.private,
        "tags": [] if note.private else note.tags,
        "aliases": [] if note.private else note.aliases,
        "refs": note.refs,
        "backlinks": note.backlinks,
    }


def write_data(notes: list[Note]) -> None:
    js_dir = PUBLIC / "js"
    js_dir.mkdir(parents=True, exist_ok=True)
    tags = sorted({tag for note in notes if not note.private for tag in note.tags})
    data = {
        "meta": {
            "generatedAt": subprocess.check_output(["date", "+%Y-%m-%d %H:%M:%S %z"], text=True).strip(),
            "noteCount": len(notes),
            "tagCount": len(tags),
        },
        "notes": [note_json(note) for note in notes],
    }
    (js_dir / "data.js").write_text(f"const SITE_DATA = {json.dumps(data, ensure_ascii=False, separators=(',', ':'))};\n", encoding="utf-8")


def _copy_into_public(source: Path, target: Path) -> None:
    target.parent.mkdir(parents=True, exist_ok=True)
    if target.is_symlink() or target.exists():
        target.unlink()
    shutil.copy2(source, target)


PUBLISHED_ASSET_PATHS = (
    Path("Aaronnote/aaronnote/style.css"),
    Path("Aaronnote/aaronnote/published-toc.js"),
    Path("Aaronnote/src/styles/widgets.css"),
    Path("Aaronnote/src/styles/theme-typora.css"),
    Path("css/aaronnote-published.css"),
)


def copy_published_assets(output_root: Path) -> None:
    for rel in PUBLISHED_ASSET_PATHS:
        source = ROOT / rel
        if source.exists():
            _copy_into_public(source, output_root / rel)


def markdown_asset_target(note: Note, raw_path: str) -> Path | None:
    path_text = unquote(raw_path.split("#", 1)[0].split("?", 1)[0]).strip()
    if not path_text or re.match(r"^[a-z][a-z0-9+.-]*:", path_text, flags=re.I):
        return None
    asset_path = Path(path_text)
    return asset_path if asset_path.is_absolute() else note.path.parent / asset_path


def note_static_asset_paths(note: Note) -> set[Path]:
    try:
        text = note.path.read_text(encoding="utf-8")
    except OSError:
        return set()

    paths: set[Path] = set()
    for raw_path in [*MD_IMAGE_RE.findall(text), *MD_LINK_RE.findall(text)]:
        asset_path = markdown_asset_target(note, raw_path)
        if not asset_path:
            continue
        if asset_path.exists() and asset_path.is_file() and asset_path.suffix.lower() in STATIC_EXTENSIONS:
            paths.add(asset_path.resolve())

    for rel_dir in (
        Path("img") / note.path.stem,
        Path("images") / note.path.stem,
        Path("assets") / "img" / note.path.stem,
    ):
        directory = note.path.parent / rel_dir
        if directory.exists():
            paths.update(
                path.resolve()
                for path in directory.rglob("*")
                if path.is_file() and path.suffix.lower() in STATIC_EXTENSIONS
            )
    return paths


def copy_note_static_assets(note: Note, output_root: Path) -> None:
    for source in note_static_asset_paths(note):
        try:
            rel = source.relative_to(ROOT)
        except ValueError:
            continue
        _copy_into_public(source, output_root / rel)


def note_kind_asset_paths(note: Note) -> set[Path]:
    kind = active_note_kind(note)
    if not kind:
        return set()
    root = ROOT / "kinds" / kind
    return {
        path
        for path in (root / "index.css", root / "index.js")
        if path.exists() and path.is_file()
    }


def copy_note_kind_assets(note: Note, output_root: Path) -> None:
    for source in note_kind_asset_paths(note):
        _copy_into_public(source, output_root / source.relative_to(ROOT))


def note_kind_assets_html(note: Note, root: str) -> str:
    kind = active_note_kind(note)
    if not kind:
        return ""
    asset_root = ROOT / "kinds" / kind
    css = asset_root / "index.css"
    js = asset_root / "index.js"
    lines: list[str] = []
    if css.exists():
        lines.append(f'  <link rel="stylesheet" href="{root}kinds/{kind}/index.css?v={NOTE_THEME_VERSION}" />')
    if js.exists():
        context = {
            "kind": kind,
            "title": note.title,
            "path": note.rel_path,
            "articleId": "content",
        }
        lines.append(
            "  <script type=\"module\">\n"
            f"    const context = {{ ...{script_json(context)}, article: document.getElementById('content') }};\n"
            f"    const mod = await import('{root}kinds/{kind}/index.js?v={NOTE_THEME_VERSION}');\n"
            "    const setup = typeof mod.default === 'function' ? mod.default : typeof mod.setup === 'function' ? mod.setup : null;\n"
            "    const cleanup = setup ? setup(context) : null;\n"
            "    window.addEventListener('pagehide', () => {\n"
            "      if (typeof cleanup === 'function') cleanup();\n"
            "      else if (typeof mod.teardown === 'function') mod.teardown(context);\n"
            "    }, { once: true });\n"
            "    window.dispatchEvent(new CustomEvent('aaronnote:kind-ready', { detail: context }));\n"
            "  </script>"
        )
    return "\n".join(lines)


def copy_static(notes: list[Note]) -> None:
    private_assets = set()
    for note in notes:
        private_assets.update(private_asset_paths(note))

    for path in iter_project_files():
        if not path.is_file() or path.resolve() in private_assets:
            continue
        rel = path.relative_to(ROOT)
        if should_skip(rel) or path.name.startswith(".") or path.name.endswith("~"):
            continue
        if rel.parts and rel.parts[0] == "roam" and path.suffix.lower() not in IMAGE_EXTENSIONS:
            continue
        if path.suffix.lower() not in STATIC_EXTENSIONS:
            continue
        _copy_into_public(path, PUBLIC / rel)

    for template, output in (("homepage.html", "index.html"), ("notes.html", "notes.html")):
        source = ROOT / template
        if source.exists():
            _copy_into_public(source, PUBLIC / output)


def clean_stale_outputs(notes: list[Note]) -> None:
    expected_html = {note.link for note in notes}
    private_assets = set()
    for note in notes:
        private_assets.update(private_asset_paths(note))
    roam_public = PUBLIC / "roam"
    if roam_public.exists():
        for source_asset in private_assets:
            try:
                rel = source_asset.relative_to(ROOT)
            except ValueError:
                continue
            public_asset = PUBLIC / rel
            if public_asset.exists() or public_asset.is_symlink():
                public_asset.unlink()
        for html_file in roam_public.glob("**/*.html"):
            rel = html_file.relative_to(PUBLIC).as_posix()
            if rel not in expected_html:
                html_file.unlink()
                deps_file_for(html_file).unlink(missing_ok=True)
        for pdf_file in roam_public.glob("**/*.pdf"):
            pdf_file.unlink()
            deps_file_for(pdf_file).unlink(missing_ok=True)
    for rel in ("diary.html", "sitemap-log.html", "CV/main.pdf"):
        (PUBLIC / rel).unlink(missing_ok=True)


def collect_notes() -> tuple[list[Note], dict[str, Note]]:
    PUBLIC.mkdir(exist_ok=True)
    notes = find_notes()
    notes_by_id = {note.id: note for note in notes}
    notes_by_rel = {note.rel_path: note for note in notes}
    backlinks: dict[str, list[str]] = {note.id: [] for note in notes}

    for note in notes:
        resolved_refs: set[str] = set()
        for ref in note.refs:
            if re.match(r"^[a-z][a-z0-9+.-]*:", ref, flags=re.I):
                continue
            ref_path = (note.path.parent / ref.split("#", 1)[0]).resolve()
            try:
                rel = ref_path.relative_to(ROOT).as_posix()
            except ValueError:
                continue
            target = notes_by_rel.get(rel)
            if target and target.id != note.id:
                resolved_refs.add(target.id)
        note.refs = sorted(resolved_refs)
        for ref in note.refs:
            backlinks.setdefault(ref, []).append(note.id)

    for note in notes:
        note.backlinks = sorted(set(backlinks.get(note.id, [])))
    return notes, notes_by_id


def arg_value(args: list[str], name: str) -> str | None:
    if name not in args:
        return None
    index = args.index(name)
    if index + 1 >= len(args):
        raise SystemExit(f"{name} requires a value")
    return args[index + 1]


def resolve_root_path(raw_path: str) -> Path:
    path = Path(raw_path).expanduser()
    if not path.is_absolute():
        path = ROOT / path
    return path.resolve()


def publish_single_note(args: list[str]) -> bool:
    raw_note = arg_value(args, "--note")
    if not raw_note:
        return False

    note_path = resolve_root_path(raw_note)
    try:
        rel = note_path.relative_to(ROOT)
    except ValueError as err:
        raise SystemExit(f"Note is outside publish root: {note_path}") from err
    if not note_path.exists() or note_path.suffix.lower() not in {".md", ".markdown"}:
        raise SystemExit(f"Not a Markdown note: {note_path}")
    if should_skip(rel):
        raise SystemExit(f"Skipped path cannot be published: {note_path}")

    output_root = PUBLIC
    raw_output_root = arg_value(args, "--output-root")
    if raw_output_root:
        output_root = resolve_root_path(raw_output_root)

    include_private = "--include-private" in args
    note = parse_note_for_export(note_path)
    output_root.mkdir(parents=True, exist_ok=True)
    copy_published_assets(output_root)
    copy_note_static_assets(note, output_root)
    copy_note_kind_assets(note, output_root)
    status = render_note_html(
        note,
        output_root=output_root,
        include_private_content=include_private,
        force=True,
    )
    output_file = output_root / note.link
    print(f"Published {note.rel_path} to {output_file} ({status})")
    return True


def main() -> None:
    args = sys.argv[1:]
    if publish_single_note(args):
        return

    notes, _notes_by_id = collect_notes()

    if "--record-state" in args:
        head = git_head()
        write_publish_state(notes, 0, len(notes), head)
        print(f"Recorded publish state for git {head[:12] if head else 'unknown'}")
        return

    head = git_head()
    if publish_state_current(notes, head):
        print(f"Published {len(notes)} Markdown notes to {PUBLIC} (git {head[:12]} unchanged, skipped)")
        return

    clean_stale_outputs(notes)
    copy_static(notes)
    rendered = 0
    skipped = 0
    for note in notes:
        status = render_note_html(note)
        rendered += status == "rendered"
        skipped += status == "skipped"
    write_data(notes)
    write_publish_state(notes, rendered, skipped, head)
    print(f"Published {len(notes)} Markdown notes to {PUBLIC} ({rendered} rendered, {skipped} skipped)")


if __name__ == "__main__":
    main()
